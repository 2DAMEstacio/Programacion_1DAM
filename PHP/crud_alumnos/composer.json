{
    "name": "iestacio/crud-alumnos",
    "description": "CRUD de alumnos en PHP con arquitectura MVC, Composer y SQLite",
    "type": "project",
    "require": {
        "php": "^8.1",
        "vlucas/phpdotenv": "^5.6",
        "bower-asset/toastr": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "repositories": {
        "asset-packagist": {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    }
}
